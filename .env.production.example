# =============================================================================
# Opslens — production environment variables
# =============================================================================
# This file documents the env vars you'll set in Render (backend) and Vercel
# (frontend). Don't commit real values — these go into each platform's dashboard.

# --- Backend (set in Render → Service → Environment) ---

# Connection string from Neon. Use the pooled connection ('-pooler' in the host).
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=postgres://...neon.tech/...?sslmode=require

# Base64-encoded 32-byte key for AES-256-GCM (used to encrypt provider tokens).
# Generate one with: openssl rand -base64 32
# (Mac users: it'll output one line ending with '=' — that whole line is the value.)
ENCRYPTION_KEY=replace-with-base64-of-32-bytes

# Comma-separated list of allowed origins. Set this to your Vercel URL.
# Once you have a custom domain, add it too.
CORS_ORIGIN=https://opslens.vercel.app

# --- Frontend (set in Vercel → Project → Settings → Environment Variables) ---

# Render gives you a URL like https://opslens-api.onrender.com after the
# backend deploys. Use HTTPS for the API and WSS for WebSockets.
NEXT_PUBLIC_API_URL=https://opslens-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://opslens-api.onrender.com
