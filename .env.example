# Backend
DATABASE_URL=postgres://opslens:opslens@localhost:5432/opslens?sslmode=disable
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Seed the 6 demo projects on first boot when the projects table is empty.
# Off by default — local dev sets this to true so the dashboard isn't blank.
# Production deliberately leaves it unset so wipes stay wiped.
SEED_DEMO=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
